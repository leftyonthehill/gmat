%---------- Mission Sequence
%----------------------------------------
BeginMissionSequence;
aop0 = dragInduced.AOP;
While dragInduced.ElapsedDays < 14 & dragInduced.ElapsedSecs < 90120
   true_lat = dragInduced.Earth.TA + dragInduced.AOP;
   true_lat = mod(true_lat, 360);
   del_a = dragInduced.SMA-Reference.SMA;
   del_e = dragInduced.ECC-Reference.ECC;
   del_i = dragInduced.INC-Reference.INC;
   del_raan = dragInduced.RAAN-Reference.RAAN;
   If 'raan_quad_check' del_raan > 180
      del_raan = del_raan-360;
   Else
      If del_raan < -180
         del_raan = del_raan+360;
      EndIf;
   EndIf;
   del_argp = dragInduced.AOP-Reference.AOP;
   If 'argp_quad_check' del_argp > 180
      del_argp = del_argp-360;
   Else
      If del_argp < -180
         del_argp = del_argp+360;
      EndIf;
   EndIf;
   del_f = dragInduced.TA-Reference.TA;
   If 'f_quad_check' del_f > 180
      del_f = del_f-360;
   Else
      If del_f < -180
         del_f = del_f+360;
      EndIf;
   EndIf;
   If 'Nominal Ops' truthState == 0
      Propagate 'Normal Flight' Synchronized DefaultProp(dragInduced) noATM(Reference) {dragInduced.ElapsedSecs = 120, OrbitColor = [128 255 255]};
      Report StateOutputs Reference.EarthMJ2000Eq.X Reference.EarthMJ2000Eq.Y Reference.EarthMJ2000Eq.Z dragInduced.EarthMJ2000Eq.X dragInduced.EarthMJ2000Eq.Y dragInduced.EarthMJ2000Eq.Z dragInduced.refRIC.X dragInduced.refRIC.Y dragInduced.refRIC.Z;
      If 'Op Zone Check' dragInduced.refRIC.Y > posV_bounds_km
         truthState = 1;
         del_a_recovery = -1 * del_a * 0.75;
      EndIf;
   Else
      If 'Wait for Maneuver 1' truthState == 1.0
         Propagate 'Wait for Perigee Pass' Synchronized DefaultProp(dragInduced) noATM(Reference) {dragInduced.ElapsedSecs = 120, dragInduced.Earth.TA = 350};
         If 'Approaching Perigee' dragInduced.Earth.TA >= 350
            truthState = 2;
            Report ReportFile1 dragInduced.ElapsedDays dragInduced.Earth.TA dragInduced.refRIC.Y del_a del_e del_argp dragInduced.Earth.HMAG dragInduced.Earth.SMA dragInduced.EarthMJ2000Eq.VMAG dragInduced.Earth.SemilatusRectum dragInduced.Earth.ECC;
         EndIf;
      Else
         If 'Perform Maneuver 1' truthState == 2
            If 'In_V_Thrusting_Bounds' dragInduced.Earth.TA < 10 | dragInduced.Earth.TA > 350
               BeginFiniteBurn thruster_V(dragInduced);
               Propagate Synchronized DefaultProp(dragInduced) noATM(Reference) {dragInduced.ElapsedSecs = 120, OrbitColor = [255 128 0]};
               EndFiniteBurn thruster_V(dragInduced);
               
               If del_a > del_a_recovery
                  truthState = 3;
                  del_e_avg = 0;
                  del_aop_avg = 0;
                  count = 0;
               EndIf;
            Else
               truthState = 1;
               Report ReportFile1 dragInduced.ElapsedDays;
            EndIf;
         Else
            If 'Wait for Maneuver 2' truthState == 3
               Propagate 'Wait for Line of Nodes' Synchronized DefaultProp(dragInduced) noATM(Reference) {dragInduced.ElapsedSecs = 120};
               
               true_lat = dragInduced.Earth.TA + dragInduced.AOP;
               true_lat = mod(true_lat, 360);
               
               del_e = dragInduced.ECC-Reference.ECC;
               del_argp = dragInduced.AOP-Reference.AOP;
               If del_argp > 180
                  del_argp = del_argp-360;
               Else
                  If del_argp < -180
                     del_argp = del_argp+360;
                  EndIf;
               EndIf;
               
               del_e_avg = del_e_avg + del_e;
               del_aop_avg = del_aop_avg + del_argp;
               count = count + 1;
               % Report ReportFile1 del_e del_e_avg del_e_tol del_argp del_aop_avg del_aop_tol count
               bManeuverMin = 170 + ricDriftRate*dragInduced.ElapsedDays;
               bManeuverMax = 190 + ricDriftRate*dragInduced.ElapsedDays;
               If 'Approaching Line of Nodes' true_lat >= bManeuverMin & true_lat < bManeuverMax %true_lat >= 170 & true_lat < 190
                  del_e_avg = del_e_avg / count;
                  del_aop_avg = del_aop_avg / count;
                  del_e_avg = abs(del_e_avg);
                  del_aop_avg = abs(del_aop_avg);
                  If del_e_avg <= del_e_tol & del_aop_avg <= del_aop_tol & count > 10
                     % Report ReportFile3 true_lat del_e_avg del_aop_avg count
                     Report ReportFile2 dragInduced.AOP Reference.AOP;
                     truthState = 0;
                     bManeuverCount = 0;
                  Else
                     If bManeuverCount == bManeuverCountMax
                        truthState = 0;
                        bManeuverCount = 0;
                     Else
                        truthState = 4;
                        radialManeuverDirection = dragInduced.refRIC.VX;
                        Report ReportFile3 true_lat dragInduced.TA dragInduced.AOP del_e_avg del_aop_avg count;
                     % Report ReportFile2 dragInduced.ElapsedDays dragInduced.Earth.TA dragInduced.refRIC.Y del_a del_e del_argp dragInduced.Earth.HMAG dragInduced.Earth.SMA dragInduced.EarthMJ2000Eq.VMAG dragInduced.Earth.SemilatusRectum dragInduced.Earth.ECC;
                     EndIf;
                  EndIf;
               EndIf;
            Else
               If 'Perform Maneuver 2' truthState == 4
                  bManeuverMin = 170 + ricDriftRate*dragInduced.ElapsedDays;
                  bManeuverMax = 190 + ricDriftRate*dragInduced.ElapsedDays;
                  If 'In_B_Thrusting_Bounds' true_lat >= bManeuverMin & true_lat < bManeuverMax %true_lat >= 170 & true_lat < 190
                     If radialManeuverDirection < 0
                        BeginFiniteBurn thruster_B_pos(dragInduced);
                        Propagate Synchronized DefaultProp(dragInduced) noATM(Reference) {dragInduced.ElapsedSecs = 120, OrbitColor = [255 255 128]};
                        EndFiniteBurn thruster_B_pos(dragInduced);
                     Else
                        BeginFiniteBurn thruster_B_neg(dragInduced);
                        Propagate Synchronized DefaultProp(dragInduced) noATM(Reference) {dragInduced.ElapsedSecs = 120, OrbitColor = [255 255 128]};
                        EndFiniteBurn thruster_B_neg(dragInduced);
                     EndIf;
                  Else
                     truthState = 3;
                     del_e_avg = 0;
                     del_aop_avg = 0;
                     count = 0;
                     bManeuverCount = bManeuverCount + 1;
                  EndIf;
               EndIf;
            EndIf;
         EndIf;
      EndIf;
   EndIf;
EndWhile;
Report ReportFile3 bManeuverCount;
Report StateOutputs dragInduced.A1ModJulian dragInduced.refRIC.X dragInduced.refRIC.Y dragInduced.refRIC.Z;
