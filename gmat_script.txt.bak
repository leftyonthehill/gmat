noATM_ForceModel.GravityField.Earth.TideModel = 'None';

%----------------------------------------
%---------- Propagators
%----------------------------------------

Create Propagator DefaultProp;
DefaultProp.FM = DefaultProp_ForceModel;
DefaultProp.Type = RungeKutta89;
DefaultProp.InitialStepSize = 60;
DefaultProp.Accuracy = 1e-10;
DefaultProp.MinStep = 0.001;
DefaultProp.MaxStep = 30;
DefaultProp.MaxStepAttempts = 10000;
DefaultProp.StopIfAccuracyIsViolated = true;

Create Propagator noATM;
noATM.FM = noATM_ForceModel;
noATM.Type = RungeKutta89;
noATM.InitialStepSize = 60;
noATM.Accuracy = 1e-10;
noATM.MinStep = 0.001;
noATM.MaxStep = 1200;
noATM.MaxStepAttempts = 100;
noATM.StopIfAccuracyIsViolated = true;

